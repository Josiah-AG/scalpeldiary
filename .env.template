# ScalpelDiary Environment Variables Template
# Copy this to .env and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# DATABASE
# ===========================================
# Local development
DATABASE_URL=postgresql://postgres:password@localhost:5432/scalpeldiary

# Production (Railway will auto-populate this)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ===========================================
# AUTHENTICATION
# ===========================================
# IMPORTANT: Change this in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ===========================================
# AWS S3 CONFIGURATION
# ===========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_S3_BUCKET=scalpeldiary-uploads

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Development
FRONTEND_URL=http://localhost:5173

# Production
# FRONTEND_URL=https://scalpeldiary.com

# ===========================================
# NOTES
# ===========================================
# 1. Never commit .env files to git
# 2. Use different values for development and production
# 3. Keep your secrets secure
# 4. Generate strong JWT_SECRET for production
# 5. Use environment-specific DATABASE_URL
